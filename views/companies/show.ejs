<h2 class="section-title"><i class="fas fa-building" style="color:#003602"></i> <%= company.name %></h2>
<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <div class="lg:col-span-2">
    <div class="highlights-carousel" style="height:300px">
      <% (company.images||[]).forEach(function(img,idx){ %>
        <div class="highlight-slide <%= idx===0?'active':'' %>" style="background:#e5e7eb">
          <img src="<%= img.url %>" alt="" class="w-full h-full object-cover">
        </div>
      <% }) %>
      <div class="highlight-controls">
        <% (company.images||[]).forEach(function(_,idx){ %>
          <div class="highlight-dot <%= idx===0?'active':'' %>" data-index="<%= idx %>"></div>
        <% }) %>
      </div>
    </div>
    <p class="mt-4 text-sm text-gray-700"><%= company.description %></p>
  </div>
  <div class="space-y-2">
    <div class="card p-4">
      <div class="text-sm text-gray-600">Categoria: <%= company.category||'-' %></div>
      <div class="text-sm text-gray-600">Telefone: <%= company.phone||'-' %></div>
      <div class="text-sm text-gray-600">Endereço: <%= company.address||'-' %></div>
      <div class="text-sm text-gray-600">Cidade: <%= company.city||'-' %></div>
      <a href="/contato" class="btn btn-primary mt-3 inline-block">Falar com a Empresa</a>
    </div>
  </div>
</div>
