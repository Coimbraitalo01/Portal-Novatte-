<h2 class="section-title"><i class="fas fa-building" style="color:#003602"></i> Empresas</h2>
<form class="grid grid-cols-1 md:grid-cols-4 gap-3 mb-4" method="get">
  <input class="border p-2 rounded" name="q" placeholder="Buscar" value="<%= (filters&&filters.q)||'' %>">
  <input class="border p-2 rounded" name="city" placeholder="Cidade" value="<%= (filters&&filters.city)||'' %>">
  <input class="border p-2 rounded" name="category" placeholder="Categoria" value="<%= (filters&&filters.category)||'' %>">
  <button class="btn btn-primary w-max">Filtrar</button>
</form>
<div class="card-grid">
  <% companies.forEach(function(c){ %>
  <div class="card">
    <div class="card-image" style="background-color:#dbeafe">
      <i class="fas fa-store text-3xl" style="color:#1d4ed8;"></i>
    </div>
    <div class="card-content">
      <h3 class="card-title"><%= c.name %></h3>
      <div class="card-meta">
        <span><i class="fas fa-map-marker-alt mr-1"></i> <%= c.city||'' %></span>
        <span><i class="fas fa-phone mr-1"></i> <%= c.phone||'' %></span>
      </div>
      <p class="card-description"><%= c.description||'' %></p>
      <div class="card-footer">
        <div class="card-actions"><a class="btn btn-primary" href="/empresas/<%= c.id %>">Ver Detalhes</a></div>
      </div>
    </div>
  </div>
  <% }) %>
</div>
