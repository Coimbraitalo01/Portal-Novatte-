<h2 class="section-title"><i class="fas fa-concierge-bell" style="color:#003602"></i> Serviços</h2>
<form class="grid grid-cols-1 md:grid-cols-3 gap-3 mb-4" method="get">
  <input class="border p-2 rounded" name="q" placeholder="Buscar" value="<%= (filters&&filters.q)||'' %>">
  <input class="border p-2 rounded" name="category" placeholder="Categoria" value="<%= (filters&&filters.category)||'' %>">
  <button class="btn btn-primary w-max">Filtrar</button>
</form>
<div class="card-grid">
  <% services.forEach(function(s){ %>
  <div class="card">
    <div class="card-image" style="background-color:#e0f2fe">
      <div class="card-badge"><%= s.category||'-' %></div>
      <i class="fas fa-wrench text-3xl" style="color:#0369a1;"></i>
    </div>
    <div class="card-content">
      <h3 class="card-title"><%= s.title %></h3>
      <p class="card-description"><%= s.description||'' %></p>
      <div class="card-footer">
        <div class="card-actions"><a class="btn btn-primary" href="/servicos/<%= s.id %>">Ver Prestadores</a></div>
      </div>
    </div>
  </div>
  <% }) %>
</div>
