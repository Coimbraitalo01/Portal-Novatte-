<h2 class="section-title"><i class="fas fa-briefcase" style="color:#003602"></i> <%= job? 'Editar' : 'Nova' %> Vaga</h2>
<form method="post" enctype="multipart/form-data" action="<%= job?('/admin/vagas/'+job.id):'/admin/vagas' %>" class="grid grid-cols-1 md:grid-cols-2 gap-3">
  <input class="border p-2 rounded" name="title" placeholder="Título" value="<%= job?job.title:'' %>" required>
  <input class="border p-2 rounded" name="company" placeholder="Empresa" value="<%= job?job.company:'' %>">
  <input class="border p-2 rounded" name="city" placeholder="Cidade" value="<%= job?job.city:'' %>">
  <select class="border p-2 rounded" name="type">
    <option value="">Tipo</option>
    <option <%= job&&job.type==='CLT'?'selected':'' %>>CLT</option>
    <option <%= job&&job.type==='PJ'?'selected':'' %>>PJ</option>
    <option <%= job&&job.type==='Estágio'?'selected':'' %>>Estágio</option>
  </select>
  <input class="border p-2 rounded" name="salary" placeholder="Salário" value="<%= job?job.salary:'' %>">
  <textarea class="border p-2 rounded md:col-span-2" name="description" rows="4" placeholder="Descrição"><%= job?job.description:'' %></textarea>
  <div class="md:col-span-2"><label class="block text-sm mb-1">Imagens</label><input type="file" name="images" multiple class="border p-2 rounded w-full"></div>
  <button class="btn btn-primary w-max md:col-span-2">Salvar</button>
</form>
<% if (job && job.images && job.images.length) { %>
  <h3 class="mixed-section-title mt-6"><i class="fas fa-images"></i> Imagens</h3>
  <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
    <% job.images.forEach(function(img){ %>
      <div class="card"><img src="<%= img.url %>" class="w-full h-32 object-cover"><form method="post" action="/vagas/imagens/<%= img.id %>/excluir" class="p-2 text-right"><button class="text-red-600 text-xs">Excluir</button></form></div>
    <% }) %>
  </div>
<% } %>
