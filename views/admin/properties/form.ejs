<h2 class="section-title"><i class="fas fa-building" style="color:#003602"></i> <%= property? 'Editar' : 'Novo' %> Imóvel</h2>
<form method="post" enctype="multipart/form-data" action="<%= property?('/admin/imoveis/'+property.id):'/admin/imoveis' %>" class="grid grid-cols-1 md:grid-cols-2 gap-3">
  <input class="border p-2 rounded" name="title" placeholder="Título" value="<%= property?property.title:'' %>" required>
  <input class="border p-2 rounded" name="price" type="number" step="0.01" placeholder="Preço" value="<%= property?property.price:'' %>" required>
  <select class="border p-2 rounded" name="status">
    <option <%= property&&property.status==='Venda'?'selected':'' %>>Venda</option>
    <option <%= property&&property.status==='Aluguel'?'selected':'' %>>Aluguel</option>
  </select>
  <input class="border p-2 rounded" name="area" type="number" placeholder="Área (m²)" value="<%= property?property.area:'' %>">
  <input class="border p-2 rounded" name="city" placeholder="Cidade" value="<%= property?property.city:'' %>">
  <input class="border p-2 rounded" name="address" placeholder="Endereço" value="<%= property?property.address:'' %>">
  <textarea class="border p-2 rounded md:col-span-2" name="description" rows="4" placeholder="Descrição"><%= property?property.description:'' %></textarea>
  <div class="md:col-span-2"><label class="block text-sm mb-1">Imagens</label><input type="file" name="images" multiple class="border p-2 rounded w-full"></div>
  <button class="btn btn-primary w-max md:col-span-2">Salvar</button>
</form>
<% if (property && property.images && property.images.length) { %>
  <h3 class="mixed-section-title mt-6"><i class="fas fa-images"></i> Imagens</h3>
  <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
    <% property.images.forEach(function(img){ %>
      <div class="card"><img src="<%= img.url %>" class="w-full h-32 object-cover"><form method="post" action="/imagens/<%= img.id %>/excluir" class="p-2 text-right"><button class="text-red-600 text-xs">Excluir</button></form></div>
    <% }) %>
  </div>
<% } %>
