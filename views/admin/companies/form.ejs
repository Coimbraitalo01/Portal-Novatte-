<h2 class="section-title"><i class="fas fa-building" style="color:#003602"></i> <%= company? 'Editar' : 'Nova' %> Empresa</h2>
<form method="post" enctype="multipart/form-data" action="<%= company?('/admin/empresas/'+company.id):'/admin/empresas' %>" class="grid grid-cols-1 md:grid-cols-2 gap-3">
  <input class="border p-2 rounded" name="name" placeholder="Nome" value="<%= company?company.name:'' %>" required>
  <input class="border p-2 rounded" name="category" placeholder="Categoria" value="<%= company?company.category:'' %>">
  <input class="border p-2 rounded" name="phone" placeholder="Telefone" value="<%= company?company.phone:'' %>">
  <input class="border p-2 rounded" name="address" placeholder="Endereço" value="<%= company?company.address:'' %>">
  <input class="border p-2 rounded" name="city" placeholder="Cidade" value="<%= company?company.city:'' %>">
  <textarea class="border p-2 rounded md:col-span-2" name="description" rows="4" placeholder="Descrição"><%= company?company.description:'' %></textarea>
  <div class="md:col-span-2"><label class="block text-sm mb-1">Imagens</label><input type="file" name="images" multiple class="border p-2 rounded w-full"></div>
  <button class="btn btn-primary w-max md:col-span-2">Salvar</button>
</form>
<% if (company && company.images && company.images.length) { %>
  <h3 class="mixed-section-title mt-6"><i class="fas fa-images"></i> Imagens</h3>
  <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
    <% company.images.forEach(function(img){ %>
      <div class="card"><img src="<%= img.url %>" class="w-full h-32 object-cover"><form method="post" action="/empresas/imagens/<%= img.id %>/excluir" class="p-2 text-right"><button class="text-red-600 text-xs">Excluir</button></form></div>
    <% }) %>
  </div>
<% } %>
